{
  "name": "repo-review-webapp",
  "version": "1.1.1",
  "type": "module",
  "exports": {
    ".": "./dist/repo-review-app.mjs",
    "./anywidget": "./dist/repo-review-anywidget.mjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bunx esbuild src/repo-review-app/repo-review-app.tsx --bundle --minify --sourcemap --outfile=docs/_static/scripts/repo-review-app.min.js --platform=browser --format=esm",
    "build-lib": "bun run build-lib-main && bun run build-anywidget",
    "build-lib-main": "bunx esbuild src/repo-review-app/repo-review-app.tsx --bundle --minify --sourcemap --outfile=dist/repo-review-app.mjs --platform=browser --format=esm",
    "build-anywidget": "bunx esbuild src/repo-review-app/anywidget.tsx --bundle --minify --sourcemap --outfile=dist/repo-review-anywidget.mjs --platform=browser --format=esm",
    "build-html": "bun build src/repo-review-app/index.html --outdir=out --minify",
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "serve": "bun src/repo-review-app/index.html",
    "test": "bun test",
    "type": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "pyodide": "^0.29.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "@mui/material": "^7.3.9",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1"
  }
}
