{
  "name": "repo-review-webapp",
  "version": "1.1.3",
  "description": "Framework that can run checks on repos",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scientific-python/repo-review.git"
  },
  "homepage": "https://repo-review.readthedocs.io",
  "bugs": {
    "url": "https://github.com/scientific-python/repo-review/issues"
  },
  "author": "Henry Schreiner <henryfs@princeton.edu>",
  "keywords": [
    "repo-review",
    "scientific-python",
    "linting",
    "repository"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/repo-review-app.mjs",
    "./anywidget": "./dist/repo-review-anywidget.mjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bunx esbuild src/repo-review-app/repo-review-app.tsx --bundle --minify --sourcemap --outfile=docs/_static/scripts/repo-review-app.min.js --platform=browser --format=esm",
    "build-lib": "bun run build-lib-main && bun run build-anywidget",
    "build-lib-main": "bunx esbuild src/repo-review-app/repo-review-app.tsx --bundle --minify --sourcemap --outfile=dist/repo-review-app.mjs --platform=browser --format=esm",
    "build-anywidget": "bunx esbuild src/repo-review-app/anywidget.tsx --bundle --minify --sourcemap --outfile=dist/repo-review-anywidget.mjs --platform=browser --format=esm",
    "build-html": "bun build src/repo-review-app/index.html --outdir=out --minify",
    "format": "prettier --write .",
    "lint": "eslint .",
    "serve": "bun src/repo-review-app/index.html",
    "test": "bun test",
    "type": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "7",
    "@mui/material": "^7.3.9",
    "pyodide": "^0.29.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
